<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fondos -->
    <SolidColorBrush x:Key="BackgroundMainBrush"
                     Color="{StaticResource Marron_Oscuro}" />

    <SolidColorBrush x:Key="BackgroundSectionBrush"
                     Color="White" />

    <!-- Textos -->
    <SolidColorBrush x:Key="TitleBrush"
                     Color="{StaticResource Marron_Oscuro}" />

    <SolidColorBrush x:Key="TextPrimaryBrush"
                     Color="{StaticResource Marron_Oscuro}" />

    <SolidColorBrush x:Key="TextSecondaryBrush"
                     Color="{StaticResource Gris_Azulado}" />

    <SolidColorBrush x:Key="TextSubtitleBrush" 
                     Color="{StaticResource Negro}" />

    <!-- Botones -->
    <SolidColorBrush x:Key="ButtonPrimaryBrush"
                     Color="{StaticResource Naranja_Cobre}" />

    <SolidColorBrush x:Key="ButtonHoverBrush"
                     Color="{StaticResource Marron_Naranja}" />

    <SolidColorBrush x:Key="ButtonTextBrush"
                     Color="{StaticResource Blanco}" />

    <!-- Iconos -->
    <SolidColorBrush x:Key="IconBrush"
                     Color="{StaticResource Naranja_Cobre}" />
    

</ResourceDictionary>