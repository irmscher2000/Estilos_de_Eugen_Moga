<Window x:Class="Estilos_de_Eugen_Moga.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Estilos_de_Eugen_Moga"
        mc:Ignorable="d"
        Title="Home" Height="1024" Width="1440"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    
    

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        

        <!-- HEADER MENU -->
        <Border Grid.Row="0"
                Background="White"
                Padding="20"
                BorderBrush="{StaticResource TextSecondaryBrush}"
                BorderThickness="0,0,0,2">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Top"
                            Margin="100,0,0,0">

                    <!-- Logo parte izquierda -->
                    <Image Source="/Images/logo.png"
                           Width="20"
                           Height="20"
                           VerticalAlignment="Center"/>

                    <TextBlock Text="DAM"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="10,0,0,0"
                               DockPanel.Dock="Left"
                               Style="{StaticResource H2Text}"/>

                </StackPanel>

                <!-- Menu derecha -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,0,40,0">

                    <TextBlock Text="Inicio"
                               Margin="15,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Style="{StaticResource MenuItemStyle}"
                               Cursor="Hand"
                               MouseLeftButtonUp="Inicio_Click"/>

                    <TextBlock Text="Sobre"
                               Margin="15,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Style="{StaticResource MenuItemStyle}"
                               Cursor="Hand"
                               MouseLeftButtonDown="Sobre_Click"/>

                    <TextBlock Text="Servicios"
                               Margin="15,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Style="{StaticResource MenuItemStyle}"
                               Cursor="Hand"
                               MouseLeftButtonDown="Servicio_Click"/>   

                    <TextBlock Text="Contacto"
                               Margin="15,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Style="{StaticResource MenuItemStyle}"
                               MouseLeftButtonDown="Contacto_Click"/> 

                </StackPanel>
                
            </Grid>

        </Border>

        <Frame Grid.Row="1"
               x:Name="MainFrame"
               NavigationUIVisibility="Hidden"
               Source="MainPage.xaml"/>
            

    </Grid>

</Window>
