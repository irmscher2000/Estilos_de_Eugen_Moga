<Window x:Class="Estilos_de_Eugen_Moga.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Estilos_de_Eugen_Moga"
        mc:Ignorable="d"
        Title="MainWindow" Height="1024" Width="1440">

    <DockPanel>

        <!-- HEADER MENU -->
        <Border Background="White"
            Padding="20"
            BorderBrush="{StaticResource TextSecondaryBrush}"
            BorderThickness="0,0,0,2"
            DockPanel.Dock="Top">
            
            
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Top"
                            Margin="100,0,0,0">

                    <!-- Logo parte izquierda -->
                    <Image Source="/Images/logo.png"
                           Width="20"
                           Height="20"
                           VerticalAlignment="Center"/>

                    <TextBlock Text="DAM"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="10,0,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               DockPanel.Dock="Left"/>

                </StackPanel>

                <!-- Menu derecha -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,0,40,0">

                    <TextBlock Text="Inicio"
                               Margin="15,0"
                               FontWeight="Bold"
                               Foreground="{StaticResource ButtonPrimaryBrush}"
                               Background="#D9D9D9"/>

                    <TextBlock Text="Sobre"
                               Margin="15,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock Text="Servicios"
                               Margin="15,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <TextBlock Text="Contacto"
                               Margin="15,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/> 

                </StackPanel>
                
            </Grid>

        </Border>

        <!-- H1 con Texto Boton mas Imagen  --> 
		<Border Background="#F1EEEA" >
			<Grid>
				<!-- Hoal -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions> 
                
                <!-- Columna izquierda -->
                <StackPanel Grid.Column="0"
                            
                            VerticalAlignment="Top"
                            Margin="40,40,40,0">
                    
                    <!-- H1 -->
                    <TextBlock Text="Desarrollamos el Futuro Digital"
                               HorizontalAlignment="Center"/>
                    
                    <!-- Texto -->
                    <TextBlock Text="En el grado superior de Desarrollo de aplicaciones multiplataforma, 
                                     aprenderás a crear aplicaciones que funcionen en diversos sistemas operativos. 
                                     Diseñarás interfaces de usuario intuitivas y atractivas."
                               TextAlignment="Left"
                               Margin="40"/>
                    
                    <!-- Botón -->
                    <Button Content="Contactar Ahora"
                            Margin="40"/>


                </StackPanel>
                
                <!-- Columna Izquierda Imagen -->
                <Border Grid.Column="1"
                        CornerRadius="16"
                        ClipToBounds="True"
                        HorizontalAlignment="Right">

                    <Image Source="/Images/escritorio.png"
                           VerticalAlignment="Top"
                           Margin="40"/>
                </Border>
                
                
            </Grid>
		</Border>
        
        <!-- Prueba -->

    </DockPanel>

</Window>
