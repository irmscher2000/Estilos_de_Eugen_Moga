<Window x:Class="Estilos_de_Eugen_Moga.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Estilos_de_Eugen_Moga"
        mc:Ignorable="d"
        Title="MainWindow" Height="1024" Width="1440">

    <DockPanel>

        <!-- HEADER MENU -->
        <Border Background="White"
            Padding="20"
            BorderBrush="#E0E0E0"
            BorderThickness="0,0,0,1"
            DockPanel.Dock="Top">
            
            
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Top"
                            Margin="100,0,0,0">

                    <!-- Logo parte izquierda -->
                    <Image Source="/Images/logo.png"
                           Width="20"
                           Height="20"
                           VerticalAlignment="Center"/>

                    <TextBlock Text="DAM"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="10,0,0,0"
                               Foreground="{StaticResource Marron_Oscuro}"
                               DockPanel.Dock="Left"/>

                </StackPanel>

                <!-- Menu derecha -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,0,40,0">

                    <TextBlock Text="Inicio"
                               Margin="15,0"
                               FontWeight="Bold"
                               Foreground="{StaticResource Naranja_Cobre}"
                               Background="#D9D9D9"/>

                    <TextBlock Text="Sobre"
                               Margin="15,0"
                               Foreground="{StaticResource Gris_Azulado}"/>

                    <TextBlock Text="Servicios"
                               Margin="15,0"
                               Foreground="{StaticResource Gris_Azulado}"/>

                    <TextBlock Text="Contacto"
                               Margin="15,0"
                               Foreground="{StaticResource Gris_Azulado}"/> 

                </StackPanel>
                
            </Grid>

        </Border>

        <!-- AQUÍ IRÁ EL CONTENIDO PRINCIPAL  -->

    </DockPanel>

</Window>
